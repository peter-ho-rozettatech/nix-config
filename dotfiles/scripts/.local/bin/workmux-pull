#!/usr/bin/env bash

set -euo pipefail

die() {
    printf 'workmux-pull: %s\n' "$*" >&2
    exit 1
}

current_worktree_root() {
    local root

    root="$(git rev-parse --show-toplevel 2> /dev/null)" \
        || die "must be run from inside a git worktree"

    cd "$root" && pwd -P
}

worktree_candidates() {
    local current_root="$1"
    local status_json

    status_json="$(workmux status --json --git 2> /dev/null || printf '[]')"

    workmux list --json \
        | jq -r --arg current_root "$current_root" --argjson statuses "$status_json" '
            def status_for($handle): first($statuses[]? | select(.worktree == $handle)) // {};

            .[] as $worktree
            | select($worktree.is_main != true and $worktree.path != $current_root)
            | (status_for($worktree.handle).git // {}) as $git
            | select(
                $worktree.has_uncommitted_changes == true
                or $git.has_staged == true
                or $git.has_unstaged == true
                or $git.has_unmerged_commits == true
              )
            | [
                (if $git.has_staged == true then "staged" else empty end),
                (if $git.has_unstaged == true then "unstaged" else empty end),
                (if $git.has_unmerged_commits == true then "unmerged" else empty end)
              ] as $flags
            | [
                $worktree.handle,
                $worktree.branch,
                $worktree.path,
                (if $flags | length > 0 then $flags | join(",") else "dirty" end)
              ]
            | @tsv
        '
}

preview_worktree() {
    local worktree_name="$1"
    local branch="$2"
    local worktree_path="$3"
    local state="$4"
    local base_head="${WORKMUX_PULL_PREVIEW_BASE_HEAD:?}"

    printf 'worktree: %s\nbranch: %s\npath: %s\nstate: %s\n\n' \
        "$worktree_name" "$branch" "$worktree_path" "$state"
    git -C "$worktree_path" status --short --branch

    printf '\nCommitted diff:\n'
    git -C "$worktree_path" diff --stat --color=always "$base_head" HEAD -- .
    git -C "$worktree_path" diff --color=always "$base_head" HEAD -- .

    printf '\nUncommitted diff:\n'
    git -C "$worktree_path" diff --stat --color=always HEAD -- .
    git -C "$worktree_path" diff --color=always HEAD -- .
}

pick_worktree() {
    local current_root="$1"
    local WORKMUX_PULL_PREVIEW_BASE_HEAD

    WORKMUX_PULL_PREVIEW_BASE_HEAD="$(git -C "$current_root" rev-parse HEAD)"
    export WORKMUX_PULL_PREVIEW_BASE_HEAD
    export -f preview_worktree

    worktree_candidates "$current_root" \
        | fzf \
            --delimiter=$'\t' \
            --with-nth=1,2,4,3 \
            --prompt 'Worktree> ' \
            --header 'Select a workmux worktree to stage and merge' \
            --preview 'bash -c '\''preview_worktree "$@"'\'' _ {1} {2} {3} {4}' \
            --preview-window 'right:60%'
}

archive_artifacts_tasks_folder() {
    local worktree_path="$1"
    local worktree_name="$2"
    local source_dir="${worktree_path}/.artifacts/${worktree_name}"
    local archive_root="${worktree_path}/.artifacts/archives"
    local archive_dir="${archive_root}/${worktree_name}"

    if [ ! -f "${source_dir}/TASKS.md" ]; then
        return 0
    fi

    if [ -e "$archive_dir" ]; then
        die "archive destination already exists: $archive_dir"
    fi

    mkdir -p "$archive_root"
    mv "$source_dir" "$archive_dir"
}

archive_superpowers_docs() {
    local worktree_path="$1"
    local worktree_name="$2"
    local sp_dir="${worktree_path}/docs/superpowers"
    local plan_source="${sp_dir}/plans/${worktree_name}.md"
    local archive_dir="${worktree_path}/docs/superpowers/archives/${worktree_name}"

    local spec_source="${sp_dir}/specs/${worktree_name}-design.md"
    if [ ! -f "$spec_source" ]; then
        spec_source="${sp_dir}/specs/${worktree_name}.md"
    fi

    if [ ! -f "$plan_source" ] && [ ! -f "$spec_source" ]; then
        return 0
    fi

    mkdir -p "$archive_dir"
    if [ -f "$plan_source" ]; then
        mv -f "$plan_source" "${archive_dir}/PLAN.md"
    fi
    if [ -f "$spec_source" ]; then
        mv -f "$spec_source" "${archive_dir}/SPEC.md"
    fi
}

archive_worktree_planning_files() {
    local worktree_path="$1"
    local worktree_name="$2"

    archive_artifacts_tasks_folder "$worktree_path" "$worktree_name"
    archive_superpowers_docs "$worktree_path" "$worktree_name"
}

stage_worktree_changes() {
    local worktree_path="$1"

    git -C "$worktree_path" add --all -- .
}

current_root="$(current_worktree_root)"

if ! selected_worktree="$(pick_worktree "$current_root")"; then
    exit 0
fi

[ -n "$selected_worktree" ] || exit 0

IFS=$'\t' read -r worktree_name _branch worktree_path _state <<< "$selected_worktree"

[ -n "$worktree_name" ] || die "selected worktree has no name"
[ -d "$worktree_path" ] || die "selected worktree path does not exist: $worktree_path"

stage_worktree_changes "$worktree_path"
workmux merge "$worktree_name"
archive_worktree_planning_files "$current_root" "$worktree_name"
