#!/usr/bin/env bash

set -euo pipefail

NIX_CONFIG_PATH="${HOME}/.nix-config"
ARCH=""
OS=""
HOST_ARG=""
PRINT_ACTIVATION_TARGET=false
ACTIVATION_TARGETS_JSON=""
SELECTED_TARGET_NAME=""
SELECTED_KIND=""
SELECTED_FLAKE_TARGET=""
TOOL_ARGS=()

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Packages to skip during automatic updates
SKIP_PACKAGES=(
    "vim-custom"
)

# Packages that use stable versioning (updated with --version=stable)
STABLE_PACKAGES=(
    "basic-memory"
    "codexbar"
    "plannotator"
    "playwriter"
    "pybetter"
)

# Helper functions for colored output
function echo_info() {
    echo -e "${BLUE}ℹ️  ${1}${NC}"
}

function echo_success() {
    echo -e "${GREEN}✅ ${1}${NC}"
}

function echo_warning() {
    echo -e "${YELLOW}⚠️  ${1}${NC}"
}

function echo_error() {
    echo -e "${RED}❌ ${1}${NC}"
}

function parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --host)
                if [[ $# -lt 2 || -z ${2:-} ]]; then
                    echo_error "--host requires a host name"
                    exit 1
                fi
                HOST_ARG="$2"
                shift 2
                ;;
            --print-activation-target)
                PRINT_ACTIVATION_TARGET=true
                shift
                ;;
            -h | --help)
                TOOL_ARGS+=("help")
                shift
                ;;
            --)
                shift
                while [[ $# -gt 0 ]]; do
                    TOOL_ARGS+=("$1")
                    shift
                done
                ;;
            *)
                TOOL_ARGS+=("$1")
                shift
                ;;
        esac
    done

    if [[ ${#TOOL_ARGS[@]} -eq 0 ]]; then
        TOOL_ARGS=("all")
    fi
}

function run_and_capture() {
    local __output_var="$1"
    shift

    local output
    local status

    set +e
    output=$("$@" 2>&1)
    status=$?
    set -e

    printf -v "$__output_var" '%s' "$output"
    return "$status"
}

function print_command_output() {
    local output="$1"

    if [[ -n $output ]]; then
        echo "$output"
    else
        echo "(command produced no output)"
    fi
}

function print_warnings_and_errors() {
    local output="$1"

    if [[ -n $output ]] && echo "$output" | grep -Eiq '(^|[[:space:]])(warning|warn|error|failed|traceback|exception)(:|[[:space:]]|$)'; then
        echo "$output" | grep -Ei '(^|[[:space:]])(warning|warn|error|failed|traceback|exception)(:|[[:space:]]|$)' || true
    fi
}

function remove_nvim_lazy_artifacts() {
    local nvim_config_path="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"
    local nvim_data_path="${XDG_DATA_HOME:-$HOME/.local/share}/nvim"
    local nvim_state_path="${XDG_STATE_HOME:-$HOME/.local/state}/nvim"
    local nvim_cache_path="${XDG_CACHE_HOME:-$HOME/.cache}/nvim"

    echo_info "Removing old lazy.nvim artifacts..."
    rm -rf \
        "$nvim_data_path/lazy" \
        "$nvim_state_path/lazy" \
        "$nvim_cache_path/lazy" \
        "$nvim_config_path/lazy-lock.json" \
        "$NIX_CONFIG_PATH/dotfiles/neovim/.config/nvim/lazy-lock.json"
}

function echo_header() {
    echo -e "${BOLD}${CYAN}🚀 ${1}${NC}"
}

function detect_system() {
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64) ARCH="x86_64" ;;
        aarch64 | arm64) ARCH="aarch64" ;;
        *)
            echo_error "Unsupported architecture: $ARCH"
            exit 1
            ;;
    esac

    if [[ $OSTYPE == "linux-gnu"* ]]; then
        if grep -q "Ubuntu" /etc/os-release 2> /dev/null; then
            OS="ubuntu"
        elif grep -q "Debian" /etc/os-release 2> /dev/null; then
            OS="debian"
        elif grep -q "NixOS" /etc/os-release 2> /dev/null; then
            OS="nixos"
        else
            echo_error "Unsupported Linux distribution. Only Ubuntu, Debian, and NixOS are supported."
            exit 1
        fi
    elif [[ $OSTYPE == "darwin"* ]]; then
        OS="darwin"
    else
        echo_error "Unsupported operating system: $OSTYPE"
        exit 1
    fi
}

detect_system

function jq_query() {
    if command -v jq > /dev/null 2>&1; then
        jq "$@"
    else
        nix run nixpkgs#jq -- "$@"
    fi
}

function activation_platform() {
    case "$OS" in
        ubuntu | debian)
            echo "home-manager"
            ;;
        darwin)
            echo "darwin"
            ;;
        nixos)
            echo "nixos"
            ;;
        *)
            echo_error "Unsupported system configuration: $OS"
            exit 1
            ;;
    esac
}

function activation_system() {
    if [[ $OS == "darwin" ]]; then
        echo "${ARCH}-darwin"
    else
        echo "${ARCH}-linux"
    fi
}

function load_activation_targets() {
    if ! ACTIVATION_TARGETS_JSON=$(nix eval --json "${NIX_CONFIG_PATH}#activationTargets" --accept-flake-config); then
        echo_error "Failed to evaluate activationTargets from $NIX_CONFIG_PATH"
        exit 1
    fi
}

function target_exists() {
    local target_name="$1"

    printf '%s' "$ACTIVATION_TARGETS_JSON" | jq_query -e --arg target "$target_name" 'has($target)' > /dev/null
}

function target_is_compatible() {
    local target_name="$1"
    local platform="$2"
    local system="$3"

    printf '%s' "$ACTIVATION_TARGETS_JSON" | jq_query -e \
        --arg target "$target_name" \
        --arg platform "$platform" \
        --arg system "$system" \
        '.[$target].platform == $platform and .[$target].system == $system' > /dev/null
}

function compatible_target_names() {
    local platform="$1"
    local system="$2"

    printf '%s' "$ACTIVATION_TARGETS_JSON" | jq_query -r \
        --arg platform "$platform" \
        --arg system "$system" \
        'to_entries | map(select(.value.platform == $platform and .value.system == $system)) | sort_by(.key) | .[].key'
}

function select_interactive_target() {
    local platform="$1"
    local system="$2"
    local compatible_names=()
    local name=""
    local choice=""
    local index=0

    while IFS= read -r name; do
        if [[ -n $name ]]; then
            compatible_names+=("$name")
        fi
    done < <(compatible_target_names "$platform" "$system")

    if [[ ${#compatible_names[@]} -eq 0 ]]; then
        echo_error "No activation targets are compatible with ${system} ${platform}"
        exit 1
    fi

    if [[ ! -r /dev/tty ]]; then
        echo_error "No matching activation target found. Pass --host <name> to choose one explicitly."
        exit 1
    fi

    echo_warning "No matching activation target found for hostname $(hostname -s 2> /dev/null || hostname)."
    echo_info "Choose a compatible activation target:"
    for index in "${!compatible_names[@]}"; do
        printf '  %d) %s\n' "$((index + 1))" "${compatible_names[$index]}" > /dev/tty
    done

    while true; do
        printf 'Select activation target [1-%d]: ' "${#compatible_names[@]}" > /dev/tty
        if ! IFS= read -r choice < /dev/tty; then
            echo_error "Failed to read activation target selection"
            exit 1
        fi

        if [[ $choice =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#compatible_names[@]})); then
            SELECTED_TARGET_NAME="${compatible_names[$((choice - 1))]}"
            return 0
        fi

        echo_error "Invalid selection: $choice"
    done
}

function set_selected_target_fields() {
    SELECTED_KIND=$(printf '%s' "$ACTIVATION_TARGETS_JSON" | jq_query -r --arg target "$SELECTED_TARGET_NAME" '.[$target].kind')
    SELECTED_FLAKE_TARGET=$(printf '%s' "$ACTIVATION_TARGETS_JSON" | jq_query -r --arg target "$SELECTED_TARGET_NAME" '.[$target].flakeTarget')
}

function resolve_activation_target() {
    local platform=""
    local system=""
    local short_hostname=""

    load_activation_targets
    platform=$(activation_platform)
    system=$(activation_system)

    if [[ -n $HOST_ARG ]]; then
        if ! target_exists "$HOST_ARG"; then
            echo_error "Unknown activation target: $HOST_ARG"
            exit 1
        fi

        if ! target_is_compatible "$HOST_ARG" "$platform" "$system"; then
            echo_error "Activation target $HOST_ARG is not compatible with detected ${system} ${platform}"
            exit 1
        fi

        SELECTED_TARGET_NAME="$HOST_ARG"
    else
        short_hostname=$(hostname -s 2> /dev/null || hostname)
        if target_exists "$short_hostname" && target_is_compatible "$short_hostname" "$platform" "$system"; then
            SELECTED_TARGET_NAME="$short_hostname"
        else
            select_interactive_target "$platform" "$system"
        fi
    fi

    set_selected_target_fields
}

function activation_flake_ref() {
    local flake_target="$1"

    if [[ $flake_target == ".#"* ]]; then
        echo "${NIX_CONFIG_PATH}#${flake_target#.#}"
    else
        echo "$flake_target"
    fi
}

function activate_selected_target() {
    local flake_ref=""

    flake_ref=$(activation_flake_ref "$SELECTED_FLAKE_TARGET")
    echo_info "Activating $SELECTED_TARGET_NAME with $SELECTED_KIND ($SELECTED_FLAKE_TARGET)..."

    case "$SELECTED_KIND" in
        home-manager)
            home-manager switch --flake "$flake_ref" --accept-flake-config
            ;;
        darwin-rebuild)
            sudo darwin-rebuild switch --flake "$flake_ref"
            ;;
        nixos-rebuild)
            sudo nixos-rebuild switch --flake "$flake_ref" --accept-flake-config
            ;;
        *)
            echo_error "Unsupported activation kind: $SELECTED_KIND"
            exit 1
            ;;
    esac
}

function pushd() {
    command pushd "$@" > /dev/null
}

function popd() {
    command popd "$@" > /dev/null
}

function tool:config {
    echo_header "Updating config"
    pushd "$NIX_CONFIG_PATH"

    local current_branch=$(git branch --show-current)
    if [[ $current_branch != "main" ]]; then
        echo_warning "Not on main branch ($current_branch), skipping config update"
        popd
        return
    fi

    echo_info "Stashing local changes..."
    git stash || true
    echo_info "Pulling latest changes..."
    git pull
    echo_info "Restoring local changes..."
    git stash pop || true
    echo_success "Config updated"
    popd
}

function tool:nvim {
    if command -v nvim &> /dev/null; then
        echo_header "Updating neovim plugins"
        remove_nvim_lazy_artifacts
        echo_info "Updating vim.pack plugins..."
        nvim --headless "+lua vim.pack.update(nil, { force = true })" +qa
        printf '\n'
        echo_info "Running neovim plugin build hooks..."
        run_nvim_build_hooks
        echo_success "Neovim plugins updated"
    else
        echo_warning "Neovim not found, skipping plugin updates"
    fi
}

function run_nvim_build_hooks {
    local hooks=()
    local hook
    local lua_name
    local output
    local status

    mapfile -t hooks < <(NVIM_BUILD_HOOKS=1 nvim --headless "+lua require('peter.plugins.lazypack').print_build_hook_names()" +qa)

    for hook in "${hooks[@]}"; do
        lua_name=${hook//\\/\\\\}
        lua_name=${lua_name//\"/\\\"}
        set +e
        output=$(NVIM_BUILD_HOOKS=1 nvim --headless "+lua require('peter.plugins.lazypack').run_build_hooks({ \"${lua_name}\" })" +qa 2>&1)
        status=$?
        set -e

        if [[ -n $output ]]; then
            printf '%s\n' "$output"
        fi

        if [[ $status -eq 139 ]]; then
            echo_warning "Neovim segfaulted after building ${hook}; continuing"
        elif [[ $status -ne 0 ]]; then
            return "$status"
        fi
    done
}

function tool:nvim:clean {
    echo_header "Cleaning neovim plugins"
    remove_nvim_lazy_artifacts
    if command -v nvim &> /dev/null; then
        echo_info "Removing inactive vim.pack plugins..."
        nvim --headless "+silent! packdel ++all" +qa
        printf '\n'
    else
        echo_warning "Neovim not found, skipping vim.pack cleanup"
    fi
    echo_success "Neovim plugins cleaned"
    # echo_info "Clearing watchman watches..."
    # watchman watch-del-all # clear watchman watches for nvim plugins
}

function tool:nvim:restore {
    if command -v nvim &> /dev/null; then
        echo_header "Restoring neovim plugins"
        nvim --headless "+lua vim.pack.update(nil, { force = true, target = 'lockfile' })" +qa
        printf '\n'
        echo_info "Running neovim plugin build hooks..."
        run_nvim_build_hooks
        echo_success "Neovim plugins restored"
    else
        echo_warning "Neovim not found, skipping plugin restore"
    fi
}

function tool:nix {
    if [[ $PRINT_ACTIVATION_TARGET == true ]]; then
        tool:nix:rebuild
        return
    fi

    echo_header "Updating nix"
    tool:nix:flake
    tool:pkgs:update "$@"
    tool:nix:rebuild
    echo_success "Nix update complete"
}

function tool:nix:flake {
    echo_header "Updating flake.lock"
    pushd "$NIX_CONFIG_PATH"
    nix flake update --accept-flake-config
    echo_success "Flake.lock updated"
    popd
}

function tool:nix:clean {
    echo_header "Cleaning nix store"
    echo_info "Cleaning user nix store..."
    nix-collect-garbage --delete-older-than 7d
    echo_info "Cleaning root nix store..."
    sudo nix-collect-garbage --delete-older-than 7d
    echo_success "Nix store cleaned"
}

function tool:nix:rebuild {
    resolve_activation_target
    if [[ $PRINT_ACTIVATION_TARGET == true ]]; then
        printf '%s\n' "$SELECTED_FLAKE_TARGET"
        return
    fi

    echo_header "Rebuilding nix config"
    activate_selected_target
    tool:fish
    echo_success "Nix config rebuilt"
}

function tool:pkgs:hashes() {
    local operation_name="${1:-manual operation}"
    shift || true
    local target_items=("$@")

    # If specific items are provided, construct file list directly
    if [[ ${#target_items[@]} -gt 0 ]]; then
        changed_files=()
        for item in "${target_items[@]}"; do
            # Convert dot notation to path (e.g., "fish-plugins.upto" -> "fish-plugins/upto")
            item_path="${item//\.//}"
            # Look for the item's nix files
            if [[ -d "pkgs/$item_path" ]]; then
                while IFS= read -r -d '' file; do
                    changed_files+=("$file")
                done < <(find "pkgs/$item_path" -name "*.nix" -print0)
            fi
        done
    else
        # Get list of files that were changed
        changed_files=($(git diff --name-only pkgs/ | grep '\.nix$' || true))
    fi

    if [[ ${#changed_files[@]} -gt 0 ]]; then
        echo_info "Updating hashes for ${#changed_files[@]} changed files..."
        for file in "${changed_files[@]}"; do
            echo_info "Checking hashes for $file"
            hash_check_start=$SECONDS

            # Try to build the package and capture any hash mismatches
            build_output=$(timeout 300 nix-build -E "with import <nixpkgs> {}; callPackage ./$file {}" 2>&1 || true)
            hash_check_duration=$((SECONDS - hash_check_start))
            echo_info "Hash check for $file took ${hash_check_duration}s"

            # Extract hash mismatches and replace them directly
            if echo "$build_output" | grep -q "hash mismatch"; then
                echo_warning "Hash mismatch detected in $file"

                # Extract both specified and got hashes from build output
                # Look for patterns like "specified: sha256-..." or "specified: sha256:..."
                specified_hash=$(echo "$build_output" | grep -oE "specified:.*sha256[:-][A-Za-z0-9+/=]+" | sed 's/specified:[[:space:]]*//' | head -1)
                got_hash=$(echo "$build_output" | grep -oE "got:.*sha256[:-][A-Za-z0-9+/=]+" | sed 's/got:[[:space:]]*//' | head -1)

                if [[ -n $specified_hash && -n $got_hash ]]; then
                    echo_info "Replacing hash in $file:"
                    echo -e "  ${YELLOW}Old:${NC} $specified_hash"
                    echo -e "  ${GREEN}New:${NC} $got_hash"

                    # Use a more robust replacement approach
                    # First, try to find and replace the exact hash string
                    if grep -Fq -- "$specified_hash" "$file"; then
                        sed -i.bak "s|$specified_hash|$got_hash|g" "$file"
                        rm -f "$file.bak"
                        echo_success "Successfully updated hash in $file"
                    elif [[ $specified_hash =~ ^sha256-A{43}=$ ]] && grep -Fq 'hash = "";' "$file"; then
                        sed -i.bak "0,/hash = \"\";/s|hash = \"\";|hash = \"$got_hash\";|" "$file"
                        rm -f "$file.bak"
                        echo_success "Successfully updated empty hash in $file"
                    else
                        echo_warning "Could not find specified hash in $file"
                        echo_info "Searching for similar hashes..."
                        grep -n "sha256" "$file" || true
                    fi
                else
                    echo_warning "Could not extract both specified and got hashes from build output for $file"
                    echo "Specified: '$specified_hash'"
                    echo "Got: '$got_hash'"
                    echo "Raw build output:"
                    echo "$build_output" | grep -A5 -B5 "hash mismatch" || true
                fi
            fi
        done
    else
        if [[ ${#target_items[@]} -gt 0 ]]; then
            echo_info "No files were changed by $operation_name for items: ${target_items[*]}"
        else
            echo_info "No files were changed by $operation_name"
        fi
    fi

    rm -rf result
    rm -rf result-*
}

function tool:pkgs:fetchgit {
    local target_items=("$@")

    echo_header "Updating nix pkgs with fetchgit"
    pushd "$NIX_CONFIG_PATH"

    if [[ ${#target_items[@]} -gt 0 ]]; then
        echo_info "Running update-nix-fetchgit on specified items: ${target_items[*]}"
        for item in "${target_items[@]}"; do
            # Convert dot notation to path (e.g., "fish-plugins.upto" -> "fish-plugins/upto")
            item_path="${item//\.//}"
            item_dir="pkgs/$item_path"
            if [[ -d $item_dir ]]; then
                while IFS= read -r -d '' file; do
                    echo_info "Running update-nix-fetchgit for $item: $file"
                    local fetchgit_output=""
                    if run_and_capture fetchgit_output update-nix-fetchgit "$file"; then
                        print_warnings_and_errors "$fetchgit_output"
                    else
                        echo_error "update-nix-fetchgit failed for $item: $file"
                        print_command_output "$fetchgit_output"
                    fi
                done < <(find "$item_dir" -type f -name "*.nix" -print0)
            else
                echo_warning "Directory $item_dir not found"
            fi
        done
    else
        # Run update-nix-fetchgit on all .nix files
        echo_info "Running update-nix-fetchgit on all .nix files..."
        while IFS= read -r -d '' file; do
            echo_info "Running update-nix-fetchgit for $file"
            local fetchgit_output=""
            if run_and_capture fetchgit_output update-nix-fetchgit "$file"; then
                print_warnings_and_errors "$fetchgit_output"
            else
                echo_error "update-nix-fetchgit failed for $file"
                print_command_output "$fetchgit_output"
            fi
        done < <(find pkgs -type f -name "*.nix" -print0)
    fi

    # Update hashes for any changed files
    tool:pkgs:hashes "update-nix-fetchgit" "${target_items[@]}"

    echo_success "Fetchgit update complete"
    popd
}

function tool:pkgs:update {
    local target_packages=("$@")

    echo_header "Updating packages with nix-update"
    pushd "$NIX_CONFIG_PATH"

    # Get the current system
    system=$(nix eval --impure --raw --expr 'builtins.currentSystem')

    # Collect all packages and plugins to update
    local all_items=()
    local stable_items=()

    if [[ ${#target_packages[@]} -gt 0 ]]; then
        all_items=("${target_packages[@]}")
        echo_info "Updating specified packages: ${all_items[*]}"
    else
        # Get list of available packages
        local packages=($(nix eval --json ".#packages.$system" --apply 'builtins.attrNames' | jq -r '.[]'))

        for package in "${packages[@]}"; do
            # Check if this is a plugin collection (fish-plugins or tmux-plugins)
            if [[ $package == "fish-plugins" || $package == "tmux-plugins" ]]; then
                # Get individual plugins from the collection
                local plugins=($(nix eval --json ".#packages.$system.$package" --apply 'builtins.attrNames' | jq -r '.[]'))
                for plugin in "${plugins[@]}"; do
                    all_items+=("$package.$plugin")
                done
            else
                # Regular package
                all_items+=("$package")
            fi
        done

        echo_info "Found ${#all_items[@]} items to update (packages + plugins)..."

        # Filter out skipped packages
        if [[ ${#SKIP_PACKAGES[@]} -gt 0 ]]; then
            local filtered_items=()
            for item in "${all_items[@]}"; do
                local skip=false
                for skip_pkg in "${SKIP_PACKAGES[@]}"; do
                    if [[ $item == "$skip_pkg" ]]; then
                        skip=true
                        echo_warning "Skipping $item (in SKIP_PACKAGES list)"
                        break
                    fi
                done
                if [[ $skip == false ]]; then
                    filtered_items+=("$item")
                fi
            done
            all_items=("${filtered_items[@]}")
        fi

    fi

    # Separate stable packages from regular packages, including explicitly requested items.
    if [[ ${#STABLE_PACKAGES[@]} -gt 0 ]]; then
        local regular_items=()
        for item in "${all_items[@]}"; do
            local is_stable=false
            for stable_pkg in "${STABLE_PACKAGES[@]}"; do
                if [[ $item == "$stable_pkg" ]]; then
                    is_stable=true
                    stable_items+=("$item")
                    break
                fi
            done
            if [[ $is_stable == false ]]; then
                regular_items+=("$item")
            fi
        done
        all_items=("${regular_items[@]}")
    fi

    failed_items=()
    successful_items=()

    for item in "${all_items[@]}"; do
        echo_info "Attempting to update: $item"

        # Determine the flake attribute path based on item type
        local attr_path=""
        if [[ $item == *"."* ]]; then
            # Plugin format: fish-plugins.upto or tmux-plugins.fingers
            attr_path="packages.$system.$item"
        else
            # Regular package
            attr_path="packages.$system.$item"
        fi

        # Check if item exists in the flake
        if ! nix eval ".#$attr_path" &> /dev/null; then
            echo_warning "Item $item not found in flake, skipping..."
            continue
        fi

        # Check if package has subpackages by looking for buildGoModule, buildNpmPackage, etc.
        package_file=$(nix eval --json ".#$attr_path.meta.position" 2> /dev/null | jq -r '.' | cut -d: -f1 2> /dev/null || echo "")

        update_args="--flake --version=branch"

        # Add subpackage flags for packages that commonly have them
        if [[ -n $package_file && -f $package_file ]]; then
            # Check for common subpackage patterns
            if grep -q "buildGoModule\|buildNpmPackage\|buildRustPackage" "$package_file" 2> /dev/null; then
                # Look for attribute assignments that might be subpackages
                subpackages=$(grep -E "^\s*[a-zA-Z][a-zA-Z0-9_-]*\s*=\s*build(Go|Npm|Rust)Module" "$package_file" | sed -E 's/^\s*([a-zA-Z][a-zA-Z0-9_-]*)\s*=.*/\1/' | grep -v "^src$" | grep -v "^version$" | grep -v "^pname$" | grep -E "^[a-zA-Z][a-zA-Z0-9_-]*$" || true)

                for subpkg in $subpackages; do
                    if [[ $subpkg != "${item##*/}" && -n $subpkg ]]; then
                        update_args="$update_args --subpackage $subpkg"
                    fi
                done
            fi
        fi

        update_output=""
        if run_and_capture update_output timeout 300 nix-update $update_args "$attr_path"; then
            echo_success "Successfully updated $item"
            print_warnings_and_errors "$update_output"
            successful_items+=("$item")
        else
            echo_error "Failed to update $item"
            print_command_output "$update_output"
            failed_items+=("$item")
        fi
    done

    # Update hashes only for successfully updated items
    if [[ ${#successful_items[@]} -gt 0 ]]; then
        echo_info "Updating hashes for ${#successful_items[@]} successfully updated items: ${successful_items[*]}"
        tool:pkgs:hashes "nix-update" "${successful_items[@]}"
    elif [[ ${#all_items[@]} -gt 0 ]]; then
        echo_warning "No items were successfully updated with nix-update, skipping hash updates"
    fi

    # Update stable packages with --version=stable
    if [[ ${#stable_items[@]} -gt 0 ]]; then
        local stable_successful_items=()
        echo_info "Updating ${#stable_items[@]} stable packages: ${stable_items[*]}"
        for item in "${stable_items[@]}"; do
            echo_info "Attempting to update (stable): $item"

            local attr_path="packages.$system.$item"

            if ! nix eval ".#$attr_path" &> /dev/null; then
                echo_warning "Item $item not found in flake, skipping..."
                continue
            fi

            update_output=""
            if run_and_capture update_output timeout 300 nix-update --flake --version=stable "$attr_path"; then
                echo_success "Successfully updated $item (stable)"
                print_warnings_and_errors "$update_output"
                stable_successful_items+=("$item")
            else
                echo_error "Failed to update $item (stable)"
                print_command_output "$update_output"
                failed_items+=("$item")
            fi
        done

        if [[ ${#stable_successful_items[@]} -gt 0 ]]; then
            echo_info "Updating hashes for stable packages: ${stable_successful_items[*]}"
            tool:pkgs:hashes "nix-update-stable" "${stable_successful_items[@]}"
        fi
    fi

    # Fallback to fetchgit if any items failed to update with nix-update
    if [[ ${#failed_items[@]} -gt 0 ]]; then
        echo_info "Running fetchgit on ${#failed_items[@]} failed items: ${failed_items[*]}"
        tool:pkgs:fetchgit "${failed_items[@]}"
    else
        echo_success "All items updated successfully with nix-update"
    fi

    popd
}

function tool:brew {
    if command -v brew &> /dev/null; then
        echo_header "Updating homebrew packages"
        echo_info "Updating brew formulae..."
        brew update
        echo_info "Upgrading packages..."
        brew upgrade --greedy --yes
        echo_success "Homebrew packages updated"
    else
        echo_warning "Homebrew not found, skipping"
    fi
}

function tool:brew:clean {
    if command -v brew &> /dev/null; then
        echo_header "Cleaning homebrew cache"
        brew cleanup --prune=7
        echo_success "Homebrew cache cleaned"
    else
        echo_warning "Homebrew not found, skipping"
    fi
}

function tool:fish {
    echo_header "Updating fish completions"
    fish -c 'fish_update_completions'
    echo_success "Fish completions updated"
}

function tool:fish:clean {
    echo_header "Cleaning fish frozen files"
    rm -f "${HOME}/.config/fish/conf.d/fish_frozen_key_bindings.fish"
    rm -f "${HOME}/.config/fish/conf.d/fish_frozen_theme.fish"
    echo_success "Fish frozen cleaned"
}

function tool:misc:clean {
    echo_header "Cleaning miscellaneous"
    # rm -f "${HOME}/.cache/opencode/models.json"
    echo_success "Miscellaneous cleaned"
}

function tool:clean {
    echo_header "Cleaning up"
    tool:nvim:clean
    tool:nix:clean
    tool:fish:clean
    if [[ $OS == "darwin" ]]; then
        tool:brew:clean
    fi
    tool:misc:clean
    echo_success "Cleanup complete"
}

function tool:restore {
    echo_header "Restoring system"
    tool:nvim:restore
    tool:nix:rebuild
    tool:clean
    echo_success "System restore complete"
}

function tool:all {
    echo_header "Running complete system update"
    tool:config
    tool:nvim
    tool:nix
    if [[ $OS == "darwin" ]]; then
        tool:brew
    fi
    tool:clean
    echo_success "🎉 Complete system update finished!"
}

function tool:list {
    compgen -A function | sed -rn 's/tool:(.*)/\1/p' | cat
}

function tool:help {
    echo_header "Update Script Help"
    printf "${BOLD}Usage:${NC} %s [TOOL] [ARGS]\n\n" "$0"
    echo -e "${BOLD}Global Options:${NC}"
    echo "  --host NAME                 Activate the named host target for rebuilds"
    echo "  --print-activation-target   Print the selected explicit rebuild target and exit"
    echo
    echo -e "${BOLD}Available Tools:${NC}"

    local tools=($(compgen -A function | sed -rn 's/tool:(.*)/\1/p'))
    for i in "${!tools[@]}"; do
        local tool="${tools[$i]}"
        local emoji=""
        case "$tool" in
            "all") emoji="🚀" ;;
            "config") emoji="⚙️" ;;
            "nvim"*) emoji="📝" ;;
            "nix"*) emoji="❄️" ;;
            "brew") emoji="🍺" ;;
            "fish") emoji="🐟" ;;
            "clean") emoji="🧹" ;;
            "restore") emoji="🔄" ;;
            "help") emoji="❓" ;;
            "list") emoji="📋" ;;
            *) emoji="🔧" ;;
        esac
        printf "  ${CYAN}%2d.${NC} ${emoji} ${BOLD}%s${NC}\n" $((i + 1)) "$tool"
    done
}

parse_args "$@"
"tool:${TOOL_ARGS[@]}"
